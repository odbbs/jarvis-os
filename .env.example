# JARVIS OS Environment Configuration
# Copy this file to .env and fill in your values

# API Keys (optional for Phase 1 — mock responses work without them)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/jarvis
DATABASE_URL_SYNC=postgresql://jarvis:jarvis@localhost:5432/jarvis

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# JARVIS Configuration
JARVIS_ENV=development
JARVIS_DEBUG=true
JARVIS_LOG_LEVEL=INFO
JARVIS_SECRET_KEY=change-this-to-a-random-secret-key

# Workspace Paths
JARVIS_WORKSPACE_ROOT=C:\JARVIS
JARVIS_PROJECTS_ROOT=C:\JARVIS\projects
JARVIS_MEMORY_ROOT=C:\JARVIS\memory
JARVIS_LOGS_ROOT=C:\JARVIS\logs

# Default Model
JARVIS_DEFAULT_MODEL=gpt

# API Server
API_HOST=0.0.0.0
API_PORT=8000
